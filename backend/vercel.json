{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/api/v1/cron/rescore-leads",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/v1/cron/scheduled-reports",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/v1/cron/sla-check",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/v1/cron/churn-scores",
      "schedule": "0 5 * * *"
    }
  ]
}