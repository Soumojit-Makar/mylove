# ─── Application ──────────────────────────────────────────────
APP_NAME=NexusCRM
APP_ENV=development
APP_VERSION=3.0.0
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
DEBUG=true

# Full public URL — used to build QStash callback URLs
# In Vercel: set this to your production domain, e.g. https://nexuscrm.vercel.app
APP_URL=http://localhost:8000

# ─── MongoDB Atlas ────────────────────────────────────────────
# https://cloud.mongodb.com → free cluster → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/nexuscrm?retryWrites=true&w=majority
MONGO_DB=nexuscrm

# ─── Redis — Upstash (serverless-friendly, per-request billing) ──
# https://console.upstash.com → Create Database → REST URL → copy Redis URL
REDIS_URL=redis://default:<password>@<host>.upstash.io:6379

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated. Add your Vercel production + preview URLs.
CORS_ORIGINS=http://localhost:5173,https://nexuscrm.vercel.app,https://nexuscrm.io

# ─── QStash (Upstash) — replaces Celery ──────────────────────
# https://console.upstash.com → QStash → Copy token + signing keys
# Leave blank to run tasks inline (local dev only)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ─── Vercel Cron protection ───────────────────────────────────
# A random secret — add to Vercel env vars AND to cron job headers
# https://vercel.com/docs/cron-jobs/manage-cron-jobs#securing-cron-jobs
CRON_SECRET=your-random-cron-secret

# ─── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-smtp-app-password
EMAIL_FROM=noreply@nexuscrm.io

# ─── AI / OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
AI_LEAD_SCORING_MODEL=gpt-4o-mini

# ─── Twilio (SMS) ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+15551234567

# ─── File Storage ─────────────────────────────────────────────
# Use 's3' in production — Vercel functions have no persistent disk
STORAGE_BACKEND=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# ─── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─── Frontend (Vite env vars — prefix with VITE_) ─────────────
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=NexusCRM
# Note: no VITE_WS_URL — frontend now uses SSE (/api/v1/stream)
